# Nägels Online — environment template.
#
# Copy this file to `.env.local` and fill in the values. Anything
# starting with EXPO_PUBLIC_ is bundled into the client and exposed
# to the browser, so use only public/anon keys here. Server-only
# secrets (service-role keys, OAuth client secrets) belong in the
# Vercel project's Environment Variables UI, never in this file.
#
# Vars that aren't set fall back to development defaults:
#   EXPO_PUBLIC_APP_URL → http://localhost:8081
# (the Supabase ones don't have safe fallbacks — set them).

# --- Supabase ---------------------------------------------------------------

# Supabase project URL — Dashboard → Project Settings → API → Project URL.
# Format: https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key — Dashboard → Project Settings → API →
# anon public key. Safe to ship to the client; RLS policies are what
# actually gate access.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Deployment context -----------------------------------------------------

# Public URL of the deployed web build, used by the Playwright demos
# (`npm run demo:6players:prod`, `npm run demo:sp:prod`) to point at
# production instead of the local dev server. Leave unset for local dev.
EXPO_PUBLIC_APP_URL=
