# Auto-generated by tests/playwright/global-setup.ts when
# LOCAL_SUPABASE=1 is set. Do NOT commit the populated .env.test —
# it contains your local service-role key.
#
# This file is a template for human inspection only. The real
# .env.test is written by globalSetup, picked up by the spawned
# Expo dev server on :8082, and deleted at the end of the run.

# Local supabase API URL — should always be 127.0.0.1 / localhost.
# globalSetup aborts the run if this ever points elsewhere.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Local supabase anon key. Different from prod — rotates on every
# `supabase start` after a `supabase stop --no-backup`.
EXPO_PUBLIC_SUPABASE_ANON_KEY=<generated by supabase status -o json>

# Public URL of the isolated Expo dev server. Playwright's baseURL.
EXPO_PUBLIC_APP_URL=http://localhost:8082
